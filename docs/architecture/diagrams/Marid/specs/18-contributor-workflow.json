{
  "specVersion": "1.0",
  "diagramType": "swimlane",
  "direction": "LR",
  "meta": {
    "title": "Contributor Workflow (Marid)"
  },
  "lanes": [
    {
      "id": "you",
      "label": {
        "text": "You"
      }
    },
    {
      "id": "local",
      "label": {
        "text": "Local repo"
      }
    },
    {
      "id": "gh",
      "label": {
        "text": "GitHub / CI"
      }
    }
  ],
  "nodes": [
    {
      "id": "clone",
      "lane": "you",
      "label": {
        "text": "clone + bun install"
      }
    },
    {
      "id": "dev",
      "lane": "local",
      "label": {
        "text": "bun dev (TUI)"
      }
    },
    {
      "id": "edit",
      "lane": "you",
      "label": {
        "text": "edit code (packages/*)"
      }
    },
    {
      "id": "check",
      "lane": "local",
      "label": {
        "text": "bun typecheck + bun lint"
      }
    },
    {
      "id": "test",
      "lane": "local",
      "label": {
        "text": "cd packages/<pkg> && bun test"
      }
    },
    {
      "id": "gen",
      "lane": "local",
      "label": {
        "text": "./script/generate.ts (if API changed)"
      }
    },
    {
      "id": "branch",
      "lane": "you",
      "label": {
        "text": "commit on branch"
      }
    },
    {
      "id": "pr",
      "lane": "gh",
      "label": {
        "text": "PR -> develop branch"
      }
    },
    {
      "id": "ci",
      "lane": "gh",
      "label": {
        "text": "20 required checks"
      }
    },
    {
      "id": "merge",
      "lane": "gh",
      "label": {
        "text": "operator merge (approval-gated)"
      }
    }
  ],
  "edges": [
    {
      "id": "w1",
      "source": "clone",
      "target": "dev"
    },
    {
      "id": "w2",
      "source": "dev",
      "target": "edit"
    },
    {
      "id": "w3",
      "source": "edit",
      "target": "check"
    },
    {
      "id": "w4",
      "source": "check",
      "target": "test"
    },
    {
      "id": "w5",
      "source": "test",
      "target": "gen"
    },
    {
      "id": "w6",
      "source": "gen",
      "target": "branch"
    },
    {
      "id": "w7",
      "source": "branch",
      "target": "pr"
    },
    {
      "id": "w8",
      "source": "pr",
      "target": "ci"
    },
    {
      "id": "w9",
      "source": "ci",
      "target": "merge"
    }
  ],
  "styles": {
    "local": {
      "fill": "#2F6BFF",
      "border": {
        "color": "#1E4FD0"
      },
      "text": {
        "color": "#ffffff"
      }
    },
    "client": {
      "fill": "#5C93FF",
      "border": {
        "color": "#2F6BFF"
      },
      "text": {
        "color": "#0B1220"
      }
    },
    "channel": {
      "fill": "#F0731F",
      "border": {
        "color": "#D9611A"
      },
      "text": {
        "color": "#ffffff"
      }
    },
    "auth": {
      "fill": "#DC2A16",
      "border": {
        "color": "#A81F10"
      },
      "text": {
        "color": "#ffffff"
      }
    },
    "core": {
      "fill": "#1C1714",
      "border": {
        "color": "#000000"
      },
      "text": {
        "color": "#F4F1EA"
      }
    }
  },
  "theme": {
    "ref": "corporate"
  }
}
