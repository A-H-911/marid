      "styleRefs": [
        "channel"
      ]
    },
    {
      "id": "cc",
      "shape": "rect",
      "label": {
        "text": "@marid/channel-client - subscribe - reconnect - re-fetch - poll self-bindings (reused unchanged)"
      },
      "styleRefs": [
        "ccpkg"
      ]
    },
    {
      "id": "auth",
      "shape": "rect",
      "label": {
        "text": "Marid Gateway - @marid/gateway - channel: token - owns U bound SSE filter - INV-001 server-enforced"
      },
      "styleRefs": [
        "auth"
      ]
    },
    {
      "id": "sess",
      "shape": "rect",
      "label": {
        "text": "Session run loop + tools + MCP"
      },
      "styleRefs": [
        "core"
      ]
    },
    {
      "id": "sse",
      "shape": "roundrect",
      "label": {
        "text": "SSE firehose (/event - /global/event)"
      }
    },
    {
      "id": "legend",
      "shape": "rect",
      "label": {
        "text": "red = @marid/gateway (API/ingress); orange = marid-whatsapp (channel gateway, a client); amber = @marid/channel-client (shared, reused from PH-6); dark = session core (reused). WhatsApp reached ONLY via the WAHA sidecar, outbound-only (WS events in / HTTP out); no WhatsApp npm dep. APPROVE token parser runs first (RISK-021)."
      }
    }
  ],
