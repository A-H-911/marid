# Marid — local environment template.  Copy to .env and fill in.
#   cp .env.example .env
# .env is git-ignored (.gitignore:5). NEVER commit real values (INV-002).
# Bun auto-loads .env from the repo root into Bun.env/process.env.

# ── Telegram test-DC tiers (EXP-007 userbot / EXP-009 web) ──────────────────
# Setup runbook: docs/execution/telegram-test-dc-setup.md
# From my.telegram.org -> API development tools (one app; account-level, test+prod):
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Bot created INSIDE the test server via @BotFather (a prod token will NOT work).
# Called via https://api.telegram.org/bot<token>/test/METHOD
TELEGRAM_TEST_BOT_TOKEN=
# GramJS StringSession minted once by the synthetic test-DC login (Step 2).
# This is a FULL LOGIN — as sensitive as a password.
TELEGRAM_TEST_SESSION=

# ── Live gateway runtime (packages/marid-telegram/src/config.ts) ────────────
# Only needed to run a real marid-telegram gateway (e.g. the EXP-005 live
# cadence tail against a throwaway BotFather bot). Not needed for the offline
# spikes or the test-DC tiers above.
# TELEGRAM_BOT_TOKEN=
# MARID_TG_ALLOW=            # comma-separated operator Telegram user ids
# TELEGRAM_API_URL=          # override Bot API base URL (e.g. .../bot<token>/test)
# MARID_TG_CADENCE_MS=
# MARID_TG_PERMISSION_TIMEOUT_MS=
# MARID_TG_POLL_TIMEOUT_SEC=
